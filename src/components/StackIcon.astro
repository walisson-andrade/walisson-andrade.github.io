---
interface Props {
  type: string;
}

const { type } = Astro.props;
---

<div
  class="w-[52px] h-[52px] rounded-[13px] bg-accent/10 flex items-center justify-center text-accent"
>
  {
    type === "automation" && (
      <svg
        width="26"
        height="26"
        viewBox="0 0 26 26"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <circle cx="6" cy="13" r="3.2" />
        <circle cx="20" cy="6" r="3.2" />
        <circle cx="20" cy="20" r="3.2" />
        <line x1="8.9" y1="11.6" x2="17.1" y2="7.2" />
        <line x1="8.9" y1="14.4" x2="17.1" y2="18.8" />
      </svg>
    )
  }
  {
    type === "fullstack" && (
      <svg
        width="26"
        height="26"
        viewBox="0 0 26 26"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <rect x="4" y="4" width="18" height="6" rx="1.6" />
        <rect x="4" y="14" width="18" height="6" rx="1.6" />
        <circle cx="8" cy="7" r="0.9" fill="currentColor" stroke="none" />
        <circle cx="8" cy="17" r="0.9" fill="currentColor" stroke="none" />
      </svg>
    )
  }
  {
    type === "data" && (
      <svg
        width="26"
        height="26"
        viewBox="0 0 26 26"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <rect x="4" y="14" width="4" height="8" rx="1" />
        <rect x="11" y="9" width="4" height="13" rx="1" />
        <rect x="18" y="5" width="4" height="17" rx="1" />
      </svg>
    )
  }
</div>
