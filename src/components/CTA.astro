---
import { getSite } from "@/data/site";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "pt" } = Astro.props;
const site = getSite(lang);
const t = useTranslations(lang);
---

<section id="contato" class="relative overflow-hidden border-t-2 border-ink">
  <div
    class="absolute -bottom-[220px] left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full pointer-events-none"
    style="background: var(--color-accent); opacity: var(--glow-blob-opacity); filter: blur(80px);"
  >
  </div>

  <div class="max-w-[760px] mx-auto px-8 py-26 text-center relative">
    <span
      class="inline-block font-mono text-[12px] tracking-[0.14em] uppercase text-on-accent bg-accent border-2 border-ink px-2.5 py-1 rounded-[5px] rotate-1"
    >
      {t("cta.tag")}
    </span>
    <h2
      class="font-display font-semibold text-[clamp(32px,5vw,50px)] leading-[1.1] tracking-[-0.01em] text-ink mt-5"
    >
      {site.cta} <span class="italic bg-accent text-on-accent px-2 rotate-[-1deg] inline-block">{t("cta.highlight")}</span>
    </h2>

    <div class="flex items-center justify-center gap-4 mt-10 flex-wrap">
      <a
        href={site.linkedin}
        target="_blank"
        rel="noopener"
        class="press-hover no-underline inline-flex items-center gap-[9px] px-[26px] py-[15px] rounded-[8px] bg-ink text-accent border-2 border-ink text-[15px] font-heading font-bold hard-shadow-sm dark:bg-accent dark:text-on-accent dark:border-accent"
      >
        LinkedIn <span class="text-base">→</span>
      </a>
      <a
        href={site.whatsappLink}
        target="_blank"
        rel="noopener"
        class="press-hover no-underline inline-flex items-center gap-[9px] px-[26px] py-[15px] rounded-[8px] bg-surface border-2 border-ink text-ink text-[15px] font-heading font-bold hard-shadow-sm"
      >
        WhatsApp <span class="font-mono text-sm text-text-secondary">{site.whatsapp}</span>
      </a>
    </div>

    <p class="mt-7 font-mono text-sm text-text-secondary">
      {site.email}
    </p>
  </div>
</section>
