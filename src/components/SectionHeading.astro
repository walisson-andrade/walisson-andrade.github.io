---
interface Props {
  tag: string;
  title: string;
  subtitle?: string;
}

const { tag, title, subtitle } = Astro.props;
---

<div>
  <span
    class="inline-block font-mono text-[12px] tracking-[0.14em] uppercase text-on-accent bg-accent border-2 border-ink px-2.5 py-1 rounded-[5px] -rotate-1"
  >
    {tag}
  </span>
  <h2
    class="font-display font-semibold text-[clamp(32px,5vw,46px)] leading-[1.05] tracking-[-0.01em] text-ink mt-4"
  >
    {title}
  </h2>
  {
    subtitle && (
      <p class="text-base text-text-muted mt-3.5 max-w-[560px] leading-relaxed">
        {subtitle}
      </p>
    )
  }
</div>
