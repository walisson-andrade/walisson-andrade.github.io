---
import { Image } from "astro:assets";
import type { Automation } from "@/lib/types";
import TechBadge from "./TechBadge.astro";

interface Props {
  automation: Automation;
}

const { automation } = Astro.props;
const hasPrint = automation.prints.length > 0;
---

<a
  href={`/automacoes/${automation.slug}`}
  class="bg-surface border border-border rounded-[18px] overflow-hidden transition-all duration-300 hover:border-accent/45 hover:shadow-[0_16px_44px_rgba(0,0,0,0.45)] hover:-translate-y-1 flex flex-col no-underline group"
>
  <div
    class="relative h-[180px] border-b border-border overflow-hidden"
    style={!hasPrint
      ? "background: repeating-linear-gradient(135deg, #181818, #181818 9px, #151515 9px, #151515 18px);"
      : undefined}
  >
    {
      hasPrint ? (
        <Image
          src={automation.prints[0]}
          alt={`Print do fluxo: ${automation.titulo}`}
          class="w-full h-full object-cover object-top"
          widths={[400, 600]}
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
        />
      ) : (
        <div class="flex items-center justify-center h-full">
          <svg width="150" height="64" viewBox="0 0 150 64" fill="none">
            <line x1="33" y1="32" x2="62" y2="32" stroke="#3A3A3A" stroke-width="2" />
            <line x1="88" y1="32" x2="117" y2="32" stroke="#3A3A3A" stroke-width="2" />
            <rect x="13" y="20" width="24" height="24" rx="6" fill="#1F1F1F" stroke="#FF6D42" stroke-width="1.6" />
            <rect x="63" y="20" width="24" height="24" rx="6" fill="#1F1F1F" stroke="#3A3A3A" stroke-width="1.6" />
            <rect x="113" y="20" width="24" height="24" rx="6" fill="#1F1F1F" stroke="#3A3A3A" stroke-width="1.6" />
          </svg>
        </div>
      )
    }
    {
      automation.prints.length > 1 && (
        <span class="absolute bottom-2 right-3 font-mono text-[10px] text-white/60 bg-black/50 px-1.5 py-0.5 rounded">
          +{automation.prints.length - 1} prints
        </span>
      )
    }
  </div>

  <div class="p-[22px] flex flex-col flex-1">
    <h3 class="font-heading font-semibold text-lg text-[#F0F0F0] mb-2">
      {automation.titulo}
    </h3>
    <p class="text-[13.5px] leading-normal text-[#8C8C8C] mb-4">
      {automation.descricao}
    </p>

    <div
      class="mb-4 flex flex-col gap-[5px] p-3 bg-surface-alt border border-[#242424] border-l-2 border-l-accent rounded-[10px]"
    >
      <span
        class="font-mono text-[10.5px] tracking-[0.1em] uppercase text-accent"
      >
        Resultado
      </span>
      <span class="text-[13px] text-[#CFCFCF] leading-[1.45]">
        {automation.metrica}
      </span>
    </div>

    <div class="flex flex-wrap gap-[7px] mt-auto">
      {automation.tecnologias.map((tech) => <TechBadge name={tech} size="sm" />)}
    </div>
    <span class="inline-flex items-center gap-1 font-mono text-xs text-accent mt-4 opacity-0 group-hover:opacity-100 transition-opacity">
      Ver detalhes <span class="text-sm">→</span>
    </span>
  </div>
</a>
