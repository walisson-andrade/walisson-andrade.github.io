---
import { Image } from "astro:assets";
import type { Automation } from "@/lib/types";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";
import TechBadge from "./TechBadge.astro";

interface Props {
  automation: Automation;
  lang?: Lang;
}

const { automation, lang = "pt" } = Astro.props;
const t = useTranslations(lang);
const hasPrint = automation.prints.length > 0;
const href = `/${lang}/automacoes/${automation.slug}`;
---

<a
  href={href}
  class="press-hover-sm bg-surface border-2 border-ink rounded-[14px] overflow-hidden hard-shadow-sm flex flex-col no-underline group"
>
  <div
    class="relative h-[180px] border-b-2 border-ink overflow-hidden"
    style={!hasPrint
      ? "background: repeating-linear-gradient(135deg, var(--color-surface), var(--color-surface) 9px, var(--color-surface-alt) 9px, var(--color-surface-alt) 18px);"
      : undefined}
  >
    {
      hasPrint ? (
        <Image
          src={automation.prints[0]}
          alt={`Print do fluxo: ${automation.titulo}`}
          class="w-full h-full object-cover object-top"
          widths={[400, 600]}
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
        />
      ) : (
        <div class="flex items-center justify-center h-full">
          <svg width="150" height="64" viewBox="0 0 150 64" fill="none">
            <line x1="33" y1="32" x2="62" y2="32" stroke="var(--color-ink)" stroke-width="2" />
            <line x1="88" y1="32" x2="117" y2="32" stroke="var(--color-ink)" stroke-width="2" />
            <rect x="13" y="20" width="24" height="24" rx="4" fill="var(--color-surface)" stroke="var(--color-accent)" stroke-width="2.4" />
            <rect x="63" y="20" width="24" height="24" rx="4" fill="var(--color-surface)" stroke="var(--color-ink)" stroke-width="1.6" />
            <rect x="113" y="20" width="24" height="24" rx="4" fill="var(--color-surface)" stroke="var(--color-ink)" stroke-width="1.6" />
          </svg>
        </div>
      )
    }
    {
      automation.prints.length > 1 && (
        <span class="absolute bottom-2 right-3 font-mono text-[10px] font-bold text-on-accent bg-accent border-2 border-ink px-1.5 py-0.5 rounded-[4px]">
          +{automation.prints.length - 1} prints
        </span>
      )
    }
  </div>

  <div class="p-[22px] flex flex-col flex-1">
    <h3 class="font-heading font-semibold text-lg text-ink mb-2">
      {automation.titulo}
    </h3>
    <p class="text-[13.5px] leading-normal text-text-muted mb-4">
      {automation.descricao}
    </p>

    <div
      class="mb-4 flex flex-col gap-[5px] p-3 bg-surface-alt border-2 border-ink border-l-[5px] border-l-accent-gold rounded-[8px]"
    >
      <span
        class="font-mono text-[10.5px] tracking-[0.1em] uppercase text-ink font-bold"
      >
        {t("projects.result")}
      </span>
      <span class="text-[13px] text-text-secondary leading-[1.45]">
        {automation.metrica}
      </span>
    </div>

    <div class="flex flex-wrap gap-[7px] mt-auto">
      {automation.tecnologias.map((tech) => <TechBadge name={tech} size="sm" />)}
    </div>
    <span class="inline-flex items-center gap-1 font-mono text-xs font-bold text-on-accent bg-accent px-2 py-0.5 rounded-[4px] mt-4 opacity-0 group-hover:opacity-100 transition-opacity w-fit">
      {t("projects.viewDetails")} <span class="text-sm">→</span>
    </span>
  </div>
</a>
