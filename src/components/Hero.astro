---
import { Image } from "astro:assets";
import { getSite } from "@/data/site";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";
import photo from "@/assets/walisson.jpg";

interface Props {
  lang?: Lang;
}

const { lang = "pt" } = Astro.props;
const site = getSite(lang);
const t = useTranslations(lang);
---

<section id="top" class="relative overflow-hidden">
  <div
    class="absolute -top-32 -right-24 w-[420px] h-[420px] rounded-full pointer-events-none animate-[float-glow_9s_ease-in-out_infinite]"
    style="background: var(--color-accent); opacity: var(--glow-blob-opacity); filter: blur(70px);"
  >
  </div>

  <div
    class="max-w-[1180px] mx-auto px-8 pt-24 md:pt-32 pb-20 md:pb-26 relative flex flex-col md:flex-row items-start md:items-center gap-12 md:gap-16"
  >
    <div class="flex-1">
      <div class="animate-[reveal_0.7s_cubic-bezier(.2,.7,.2,1)_both]">
        <span
          class="inline-flex items-center gap-[9px] px-3.5 py-[7px] bg-surface border-2 border-ink rounded-[6px] font-mono text-xs text-ink hard-shadow-sm -rotate-1"
        >
          <span
            class="w-[7px] h-[7px] rounded-full bg-accent-gold animate-[pulse-dot_2.2s_ease-in-out_infinite]"
          ></span>
          {site.confidentiality}
        </span>
      </div>

      <h1
        class="animate-[reveal_0.7s_cubic-bezier(.2,.7,.2,1)_80ms_both] font-display font-semibold text-[clamp(42px,8.5vw,84px)] leading-[0.98] tracking-[-0.015em] text-ink mt-6 md:mt-[28px] max-w-[880px]"
      >
        {site.heroTitleMain}
        <span
          class="italic bg-accent text-on-accent px-2 -mx-1 rotate-[-1deg] inline-block"
          >{site.heroTitleHighlight}</span
        >
      </h1>

      <p
        class="animate-[reveal_0.7s_cubic-bezier(.2,.7,.2,1)_160ms_both] text-lg md:text-xl leading-relaxed text-text-secondary mt-6 md:mt-[26px] max-w-[600px]"
      >
        {site.subtitle}
      </p>

      <div
        class="animate-[reveal_0.7s_cubic-bezier(.2,.7,.2,1)_240ms_both] flex items-center gap-5 mt-8 md:mt-[42px] flex-wrap"
      >
        <a
          href="#contato"
          class="press-hover no-underline inline-flex items-center gap-[9px] px-6 md:px-[26px] py-[15px] rounded-[8px] bg-ink text-accent border-2 border-ink text-[15px] font-heading font-bold hard-shadow-sm dark:bg-accent dark:text-on-accent dark:border-accent"
        >
          {t("nav.cta")} <span class="text-base">→</span>
        </a>
        <a
          href="#projetos"
          class="press-hover no-underline inline-flex items-center px-6 md:px-[26px] py-[15px] rounded-[8px] bg-surface border-2 border-ink text-ink text-[15px] font-heading font-bold hard-shadow-sm"
        >
          {t("stacks.cta")}
        </a>
        <span
          class="hidden sm:inline-flex items-center gap-2 ml-1.5 text-[13.5px] text-text-muted font-mono"
        >
          <span
            class="w-2 h-2 rounded-full bg-success"
          ></span>
          {t("hero.available")}
        </span>
      </div>
    </div>

    <div
      class="animate-[reveal_0.7s_cubic-bezier(.2,.7,.2,1)_200ms_both] shrink-0 hidden md:block"
    >
      <div
        class="w-[200px] h-[200px] lg:w-[240px] lg:h-[240px] rounded-[16px] overflow-hidden border-2 border-ink hard-shadow rotate-2 bg-surface"
      >
        <Image
          src={photo}
          alt="Walisson Andrade"
          width={480}
          height={480}
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
