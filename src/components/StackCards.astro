---
import { stacks } from "@/data/stacks";
import SectionHeading from "./SectionHeading.astro";
import StackIcon from "./StackIcon.astro";
import TechBadge from "./TechBadge.astro";
---

<section id="skills" class="max-w-[1180px] mx-auto px-8 py-24">
  <SectionHeading tag="Stacks de habilidades" title="Três frentes de atuação" />

  <div
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[22px] mt-11"
  >
    {
      stacks.map((stack) => (
        <a
          href={`#projetos`}
          data-activate-tab={stack.tabTarget}
          class="stack-link block bg-surface border border-border rounded-[18px] p-[30px] transition-all duration-300 hover:border-accent/50 hover:shadow-[0_14px_40px_rgba(0,0,0,0.4)] hover:-translate-y-1 no-underline cursor-pointer group"
        >
          <StackIcon type={stack.icon} />
          <h3 class="font-heading font-semibold text-[21px] text-[#F2F2F2] mt-[22px] mb-2">
            {stack.title}
          </h3>
          <p class="text-sm leading-normal text-text-muted mb-5">
            {stack.description}
          </p>
          <div class="flex flex-wrap gap-[7px] mb-4">
            {stack.technologies.map((tech) => (
              <TechBadge name={tech} />
            ))}
          </div>
          <span class="inline-flex items-center gap-1 font-mono text-xs text-accent opacity-0 group-hover:opacity-100 transition-opacity">
            Ver projetos <span class="text-sm">→</span>
          </span>
        </a>
      ))
    }
  </div>
</section>

<script>
  document.querySelectorAll<HTMLAnchorElement>(".stack-link").forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const tabId = link.dataset.activateTab;
      const tabBtn = document.querySelector<HTMLButtonElement>(
        `.tab-btn[data-tab="${tabId}"]`,
      );
      if (tabBtn) tabBtn.click();
      document
        .getElementById("projetos")
        ?.scrollIntoView({ behavior: "smooth" });
    });
  });
</script>
