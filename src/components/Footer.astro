---
import { getSite } from "@/data/site";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "pt" } = Astro.props;
const site = getSite(lang);
const t = useTranslations(lang);
---

<footer class="border-t-2 border-[#15130E] bg-[#15130E]">
  <div
    class="max-w-[1180px] mx-auto px-8 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4"
  >
    <div class="flex items-center gap-2.5">
      <span class="w-2.5 h-2.5 rounded-[3px] bg-accent border border-accent inline-block"></span>
      <span class="font-heading font-semibold text-[15px] text-[#F3EEDD]">
        {site.name}
      </span>
    </div>
    <div class="flex items-center gap-[9px] font-mono text-xs text-[#948C74]">
      <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
      {t("footer.confidentiality")}
    </div>
  </div>
  <div class="border-t border-white/10">
    <div
      class="max-w-[1180px] mx-auto px-8 py-[18px] flex flex-col sm:flex-row items-center justify-between gap-2.5"
    >
      <span class="font-mono text-[11.5px] text-[#948C74]">
        &copy; 2026 {site.name}
      </span>
      <span class="font-mono text-[11.5px] text-[#948C74]">
        {t("footer.tagline")}
      </span>
    </div>
  </div>
</footer>
