---
import { site } from "@/data/site";
---

<footer class="border-t border-[#1C1C1C] bg-[#0B0B0B]">
  <div
    class="max-w-[1180px] mx-auto px-8 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4"
  >
    <div class="flex items-center gap-2.5">
      <span class="w-2.5 h-2.5 rounded-[3px] bg-accent inline-block"></span>
      <span class="font-heading font-semibold text-[15px] text-[#E8E8E8]">
        {site.name}
      </span>
    </div>
    <div class="flex items-center gap-[9px] font-mono text-xs text-[#777]">
      <span class="w-1.5 h-1.5 rounded-full bg-[#3A3A3A]"></span>
      Projetos reais em produção. Detalhes de clientes não divulgados por contrato
    </div>
  </div>
  <div class="border-t border-[#161616]">
    <div
      class="max-w-[1180px] mx-auto px-8 py-[18px] flex flex-col sm:flex-row items-center justify-between gap-2.5"
    >
      <span class="font-mono text-[11.5px] text-text-dim">
        &copy; 2026 {site.name}
      </span>
      <span class="font-mono text-[11.5px] text-text-dim">
        Automação &middot; Full Stack &middot; Dados
      </span>
    </div>
  </div>
</footer>
