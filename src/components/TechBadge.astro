---
import { getTechIconSvg } from "@/lib/techIcons";

interface Props {
  name: string;
  size?: "sm" | "md";
}

const { name, size = "md" } = Astro.props;
const icon = getTechIconSvg(name);

const sizeClasses = {
  sm: "px-[9px] py-1 text-[11px] rounded-[5px] gap-[5px]",
  md: "px-2.5 py-[5px] text-[11.5px] rounded-[6px] gap-1.5",
};
---

<span
  class:list={[
    "inline-flex items-center bg-surface border-2 border-ink font-mono text-ink",
    sizeClasses[size],
  ]}
>
  {icon && <span class="shrink-0 leading-none" set:html={icon} />}
  {name}
</span>
