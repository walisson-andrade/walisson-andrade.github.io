---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Alternar tema claro/escuro"
  class:list={[
    "theme-toggle shrink-0 w-9 h-9 flex items-center justify-center rounded-[7px] border-2 border-ink bg-surface text-ink hover:bg-accent hover:text-on-accent transition-colors",
    className,
  ]}
>
  <svg
    class="theme-icon-sun"
    width="17"
    height="17"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
  >
    <circle cx="12" cy="12" r="4.6" />
    <path d="M12 2.5v2.4M12 19.1v2.4M4.2 4.2l1.7 1.7M18.1 18.1l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.2 19.8l1.7-1.7M18.1 5.9l1.7-1.7" />
  </svg>
  <svg
    class="theme-icon-moon hidden"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="currentColor"
  >
    <path d="M20.4 14.7A8.6 8.6 0 019.3 3.6a.9.9 0 00-1.1-1.2A10.4 10.4 0 1021.6 15.8a.9.9 0 00-1.2-1.1z" />
  </svg>
</button>

<script>
  function applyIcon(btn: Element) {
    const isDark = document.documentElement.classList.contains("dark");
    btn.querySelector(".theme-icon-sun")?.classList.toggle("hidden", isDark);
    btn.querySelector(".theme-icon-moon")?.classList.toggle("hidden", !isDark);
  }

  document.querySelectorAll(".theme-toggle").forEach((btn) => {
    applyIcon(btn);
    btn.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      document.querySelectorAll(".theme-toggle").forEach(applyIcon);
    });
  });
</script>
