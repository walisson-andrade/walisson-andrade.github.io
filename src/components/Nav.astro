---
import { getSite } from "@/data/site";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";
import ThemeToggle from "./ThemeToggle.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  lang?: Lang;
}

const { lang = "pt" } = Astro.props;
const site = getSite(lang);
const t = useTranslations(lang);
---

<header
  class="sticky top-0 z-60 backdrop-blur-xl bg-bg/90 border-b-2 border-ink"
>
  <div
    class="max-w-[1180px] mx-auto px-8 py-[15px] flex items-center justify-between"
  >
    <a href="#top" class="flex items-center gap-2.5 no-underline">
      <span class="w-[13px] h-[13px] rounded-[3px] bg-accent border-2 border-ink inline-block"
      ></span>
      <span
        class="font-heading font-bold text-base text-ink tracking-tight"
        >{site.name}</span
      >
    </a>

    <div class="flex items-center gap-3 md:hidden">
      <LanguageSwitcher lang={lang} path="/" />
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        class="flex flex-col gap-1.5 p-2"
        aria-label="Menu"
      >
        <span class="w-5 h-0.5 bg-ink transition-all"></span>
        <span class="w-5 h-0.5 bg-ink transition-all"></span>
        <span class="w-5 h-0.5 bg-ink transition-all"></span>
      </button>
    </div>

    <nav id="nav-links" class="hidden md:flex items-center gap-8">
      <a
        href="#skills"
        class="no-underline text-text-secondary text-sm font-medium hover:text-ink transition-colors"
        >{t("nav.skills")}</a
      >
      <a
        href="#projetos"
        class="no-underline text-text-secondary text-sm font-medium hover:text-ink transition-colors"
        >{t("nav.projects")}</a
      >
      <a
        href="#experiencia"
        class="no-underline text-text-secondary text-sm font-medium hover:text-ink transition-colors"
        >{t("nav.experience")}</a
      >
      <LanguageSwitcher lang={lang} path="/" />
      <ThemeToggle />
      <a
        href="#contato"
        class="press-hover-sm no-underline inline-flex items-center px-[17px] py-[9px] rounded-[7px] bg-ink text-accent border-2 border-ink text-sm font-heading font-bold dark:bg-accent dark:text-on-accent dark:border-accent"
        >{t("nav.cta")}</a
      >
    </nav>
  </div>

  <nav
    id="mobile-nav"
    class="md:hidden hidden flex-col gap-4 px-8 pb-6 border-t-2 border-ink"
  >
    <a
      href="#skills"
      class="no-underline text-text-secondary text-sm font-medium hover:text-ink transition-colors pt-4"
      >{t("nav.skills")}</a
    >
    <a
      href="#projetos"
      class="no-underline text-text-secondary text-sm font-medium hover:text-ink transition-colors"
      >{t("nav.projects")}</a
    >
    <a
      href="#experiencia"
      class="no-underline text-text-secondary text-sm font-medium hover:text-ink transition-colors"
      >{t("nav.experience")}</a
    >
    <a
      href="#contato"
      class="no-underline inline-flex items-center justify-center px-[17px] py-[9px] rounded-[7px] bg-ink text-accent border-2 border-ink text-sm font-heading font-bold dark:bg-accent dark:text-on-accent dark:border-accent"
      >{t("nav.cta")}</a
    >
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const nav = document.getElementById("mobile-nav");
  btn?.addEventListener("click", () => {
    nav?.classList.toggle("hidden");
    nav?.classList.toggle("flex");
  });
  nav?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      nav?.classList.add("hidden");
      nav?.classList.remove("flex");
    });
  });
</script>
