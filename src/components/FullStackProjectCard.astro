---
import type { FullStackProject } from "@/lib/types";
import TechBadge from "./TechBadge.astro";

interface Props {
  project: FullStackProject;
}

const { project } = Astro.props;
---

<div
  class="bg-surface border border-border rounded-[18px] p-[30px] flex flex-col transition-all duration-300 hover:border-accent/45 hover:shadow-[0_16px_44px_rgba(0,0,0,0.45)] hover:-translate-y-1"
>
  <div class="flex items-center justify-between">
    <span
      class="inline-flex px-[11px] py-[5px] bg-accent/10 border border-accent/25 rounded-full font-mono text-[11px] tracking-wide text-accent"
    >
      {project.segment}
    </span>
    <span class="font-mono text-[13px] text-text-dim">{project.number}</span>
  </div>

  <h3
    class="font-heading font-semibold text-[22px] leading-[1.2] text-[#F2F2F2] mt-[18px] mb-4"
  >
    {project.title}
  </h3>

  <div class="flex flex-col gap-[9px] mb-5">
    {
      project.metrics.map((metric) => (
        <div class="flex items-start gap-2.5">
          <span class="text-accent text-sm">{metric.icon}</span>
          <span class="text-[14.5px] text-[#C4C4C4] leading-[1.45]">
            {metric.text}
            <strong class="text-white font-semibold">{metric.highlight}</strong>
          </span>
        </div>
      ))
    }
  </div>

  <div class="flex flex-wrap gap-[7px] mb-5">
    {project.technologies.map((tech) => <TechBadge name={tech} />)}
  </div>

  <div
    class="mt-auto flex flex-col gap-[5px] p-3.5 px-4 bg-surface-alt border border-[#242424] border-l-2 border-l-accent rounded-[10px]"
  >
    <span
      class="font-mono text-[10.5px] tracking-[0.1em] uppercase text-accent"
    >
      {project.technicalHighlight.label}
    </span>
    <span class="text-[13.5px] text-[#CFCFCF] leading-[1.45]">
      {project.technicalHighlight.description}
    </span>
  </div>
</div>
