---
import type { FullStackProject } from "@/lib/types";
import TechBadge from "./TechBadge.astro";

interface Props {
  project: FullStackProject;
}

const { project } = Astro.props;
---

<div
  class="press-hover-sm bg-surface border-2 border-ink rounded-[14px] p-[30px] flex flex-col hard-shadow-sm"
>
  <div class="flex items-center justify-between">
    <span
      class="inline-flex px-[11px] py-[5px] bg-accent border-2 border-ink rounded-[5px] font-mono text-[11px] font-bold tracking-wide text-on-accent"
    >
      {project.segment}
    </span>
    <span class="font-mono text-[13px] text-text-dim">{project.number}</span>
  </div>

  <h3
    class="font-heading font-semibold text-[22px] leading-[1.2] text-ink mt-[18px] mb-4"
  >
    {project.title}
  </h3>

  <div class="flex flex-col gap-[9px] mb-5">
    {
      project.metrics.map((metric) => (
        <div class="flex items-start gap-2.5">
          <span class="text-accent-gold text-sm">{metric.icon}</span>
          <span class="text-[14.5px] text-text-secondary leading-[1.45]">
            {metric.text}
            <strong class="text-ink font-semibold">{metric.highlight}</strong>
          </span>
        </div>
      ))
    }
  </div>

  <div class="flex flex-wrap gap-[7px] mb-5">
    {project.technologies.map((tech) => <TechBadge name={tech} />)}
  </div>

  <div
    class="mt-auto flex flex-col gap-[5px] p-3.5 px-4 bg-surface-alt border-2 border-ink border-l-[5px] border-l-accent-gold rounded-[8px]"
  >
    <span
      class="font-mono text-[10.5px] tracking-[0.1em] uppercase text-ink font-bold"
    >
      {project.technicalHighlight.label}
    </span>
    <span class="text-[13.5px] text-text-secondary leading-[1.45]">
      {project.technicalHighlight.description}
    </span>
  </div>
</div>
