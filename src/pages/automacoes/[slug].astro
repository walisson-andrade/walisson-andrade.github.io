---
import { Image } from "astro:assets";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { loadAutomations } from "@/lib/loadAutomations";
import TechBadge from "@/components/TechBadge.astro";
import { site } from "@/data/site";

export const getStaticPaths = (() => {
  const automations = loadAutomations();
  return automations.map((auto) => ({
    params: { slug: auto.slug },
    props: { automation: auto },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { automation } = Astro.props as Props;
---

<BaseLayout
  title={`${automation.titulo} | ${site.name}`}
  description={automation.descricao}
>
  <header
    class="sticky top-0 z-60 backdrop-blur-xl bg-bg/72 border-b border-[#1C1C1C]"
  >
    <div
      class="max-w-[1180px] mx-auto px-8 py-[15px] flex items-center justify-between"
    >
      <a href="/" class="flex items-center gap-2.5 no-underline">
        <span class="w-[11px] h-[11px] rounded-[3px] bg-accent inline-block"
        ></span>
        <span
          class="font-heading font-semibold text-base text-[#F5F5F4] tracking-tight"
          >{site.name}</span
        >
      </a>
      <a
        href="/#projetos"
        class="no-underline inline-flex items-center gap-2 text-text-secondary text-sm hover:text-white transition-colors"
      >
        <span>←</span> Voltar aos projetos
      </a>
    </div>
  </header>

  <main class="max-w-[860px] mx-auto px-8 pt-16 pb-24">
    <div class="mb-10">
      <span
        class="inline-flex items-center gap-2 px-3 py-1.5 bg-accent/10 border border-accent/25 rounded-full font-mono text-[11px] text-accent mb-5"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        Automação n8n
      </span>
      <h1
        class="font-heading font-semibold text-[clamp(28px,5vw,40px)] leading-[1.1] tracking-tight text-[#F5F5F4]"
      >
        {automation.titulo}
      </h1>
      <p class="text-lg text-text-muted mt-4 leading-relaxed max-w-[700px]">
        {automation.descricao}
      </p>
    </div>

    {
      automation.prints.length > 0 && (
        <div class="flex flex-col gap-4 mb-12">
          {automation.prints.map((print, i) => (
            <div class="rounded-[14px] overflow-hidden border border-border bg-surface">
              <Image
                src={print}
                alt={`Print ${i + 1} do fluxo: ${automation.titulo}`}
                class="w-full h-auto"
                widths={[600, 900]}
                sizes="(max-width: 860px) 100vw, 860px"
              />
            </div>
          ))}
        </div>
      )
    }

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-12">
      <div class="p-6 bg-surface border border-border rounded-[14px]">
        <span
          class="font-mono text-[11px] tracking-[0.1em] uppercase text-accent"
        >
          Problema
        </span>
        <p class="text-[15px] text-[#C4C4C4] leading-relaxed mt-2">
          {automation.problema}
        </p>
      </div>
      <div class="p-6 bg-surface border border-border rounded-[14px]">
        <span
          class="font-mono text-[11px] tracking-[0.1em] uppercase text-accent"
        >
          Resultado
        </span>
        <p class="text-[15px] text-[#C4C4C4] leading-relaxed mt-2">
          {automation.resultado}
        </p>
      </div>
    </div>

    <div
      class="p-6 bg-surface-alt border border-[#242424] border-l-2 border-l-accent rounded-[14px] mb-12"
    >
      <span
        class="font-mono text-[11px] tracking-[0.1em] uppercase text-accent"
      >
        Métrica de impacto
      </span>
      <p
        class="font-heading font-semibold text-xl text-[#F2F2F2] mt-2 leading-snug"
      >
        {automation.metrica}
      </p>
    </div>

    {
      automation.destaques.length > 0 && (
        <div class="mb-12">
          <h2 class="font-heading font-semibold text-lg text-[#F2F2F2] mb-4">
            Destaques técnicos
          </h2>
          <ul class="flex flex-col gap-2.5">
            {automation.destaques.map((d) => (
              <li class="flex items-start gap-3 text-[15px] text-[#C4C4C4] leading-relaxed">
                <span class="text-accent mt-0.5 shrink-0">↗</span>
                {d}
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <div>
      <h2 class="font-heading font-semibold text-lg text-[#F2F2F2] mb-4">
        Tecnologias
      </h2>
      <div class="flex flex-wrap gap-2">
        {automation.tecnologias.map((tech) => <TechBadge name={tech} />)}
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-border">
      <div class="flex items-center gap-2 font-mono text-xs text-text-dim">
        <span class="w-1.5 h-1.5 rounded-full bg-[#3A3A3A]"></span>
        Projeto real em produção. Detalhes do cliente não divulgados por contrato
      </div>
    </div>
  </main>
</BaseLayout>
